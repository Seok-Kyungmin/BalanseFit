<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- JAVA와 연결할 Mapper 파일 설정 -->
<mapper namespace="com.balansefit.persistance.mapper.IUserDietMapper">

    <!-- 유저 식단 정보 리스트 -->
    <select id="getUserDietList" resultType="UserDietDTO">
        SELECT DIET_SEQ, DIET_NAME, DIET_CALORIES
        FROM USER_DIET
        ORDER BY DIET_SEQ ASC
    </select>

    <!-- 유저 식단 정보 등록 -->
    <insert id="insertUserDietInfo" parameterType="UserDietDTO">
        INSERT INTO USER_DIET(
            DIET_SEQ, DIET_NAME, FOOD_NAME, FOOD_NUMBER, DIET_CALORIES,
            USER_ID, REG_ID, REG_DT, CHG_ID, CHG_DT)
        VALUES (
                       (SELECT NULLIF (MAX(A.DIET_SEQ),0)+1 FROM DIET A),
                       #{diet_name}, #{food_name}, #{food_number}, #{diet_calories},
                       #{user_id}, 0, #{user_id}, SYSDATE(), #{user_id}, SYSDATE())
    </insert>

    <!-- 유저 식단 정보 상세보기 -->
    <select id="getUserDietInfo" resultType="UserDietDTO">
        SELECT DIET_SEQ, DIET_NAME, DIET_CALORIES
        FROM USER_DIET
        WHERE DIET_SEQ = #{diet_seq}
    </select>



