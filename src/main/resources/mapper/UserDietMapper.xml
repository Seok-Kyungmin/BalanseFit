    <!-- 유저 식단 정보 삭제 -->
    <delete id="deleteUserDietInfo" parameterType="UserDietDTO">
        DELETE FROM USER_DIET
        WHERE DIET_SEQ = #{diet_seq}
    </delete>

    <!-- 유저 식품 리스트 -->
    <select id="getUserFoodList" resultType="FoodDTO">
        SELECT FOOD_SEQ, FOOD_NAME
        FROM FOOD_INFO
        ORDER BY FOOD_SEQ ASC
    </select>

</mapper>